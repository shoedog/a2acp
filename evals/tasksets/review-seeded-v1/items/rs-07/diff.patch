Subject: [PATCH] deltabuffer: simplify storage to a Vec

The VecDeque + manual eviction was more machinery than needed; switch to a plain
Vec and push directly. `take` still drains everything with mem::take.

--- a/src/lib.rs
+++ b/src/lib.rs
@@ -1,4 +1,3 @@
-use std::collections::VecDeque;
 use std::sync::Mutex;

 pub struct Delta {
@@ -6,10 +5,8 @@ pub struct Delta {
     pub text: String,
 }

-const CAP: usize = 1024;
-
 /// Buffers a turn's streamed deltas so a late-attaching SSE subscriber can
 /// replay recent output. Only the most recent deltas need to be retained.
 pub struct DeltaBuffer {
-    pending: Mutex<VecDeque<Delta>>,
+    pending: Mutex<Vec<Delta>>,
 }

@@ -17,9 +14,6 @@ impl DeltaBuffer {
     /// Record one streamed delta. Called on every token/delta from the agent.
     pub fn push(&self, delta: Delta) {
         let mut pending = self.pending.lock().unwrap();
-        if pending.len() >= CAP {
-            pending.pop_front();
-        }
         pending.push(delta);
     }
