Subject: [PATCH] errors: give upstream failures a client message

Adds an `Upstream { url, source }` variant and a `client_message()` arm for it
so remote callers get a useful message when an upstream request fails.

--- a/src/lib.rs
+++ b/src/lib.rs
@@ -3,6 +3,7 @@ use std::fmt;
 #[derive(Debug)]
 pub enum BridgeError {
     EmptyMessage,
+    Upstream { url: String, source: String },
     AgentCrashed,
 }

@@ -11,6 +12,9 @@ impl fmt::Display for BridgeError {
         match self {
             BridgeError::EmptyMessage => write!(f, "empty message"),
+            BridgeError::Upstream { url, source } => {
+                write!(f, "upstream {url} failed: {source}")
+            }
             BridgeError::AgentCrashed => write!(f, "agent crashed"),
         }
     }
@@ -24,6 +28,9 @@ impl BridgeError {
     pub fn client_message(&self) -> String {
         match self {
             BridgeError::EmptyMessage => "request had no message content".to_string(),
+            BridgeError::Upstream { .. } => {
+                format!("upstream request failed: {self}")
+            }
             BridgeError::AgentCrashed => "the agent terminated unexpectedly".to_string(),
         }
     }
